# OpenRouter API-Key – kostenlos erhältlich unter https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Hauptmodell: starkes multimodales Vision-Modell für Bildanalyse
OPENROUTER_PRIMARY_MODEL=google/gemini-2.5-flash

# Fallback-Modell, falls das Hauptmodell nicht verfügbar / überlastet ist
OPENROUTER_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free

# Modell für reine Text-Aufgaben (Rezeptvorschläge ohne Bild)
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini

# Optionale Angaben für OpenRouter-Ranking (siehe https://openrouter.ai/docs)
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=FridgeAI
